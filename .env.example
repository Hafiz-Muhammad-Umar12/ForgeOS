# DevOS — local development environment template.
# Copy to `.env` and fill values. NEVER commit `.env` (see .gitignore).
# Real secrets are resolved via the secret manager (secret-management component).

# --- Application ---
APP_ENV=development
APP_NAME=devos
LOG_LEVEL=info
LOG_FORMAT=json

# --- OpenTelemetry (observability foundation) ---
OTEL_ENABLED=true
OTEL_SERVICE_NAME=devos
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# --- Event Bus (NATS JetStream) — wired in a later Sprint 0 component ---
NATS_URL=nats://localhost:4222

# --- Reserved for later components (do not use yet) ---
# POSTGRES_URL=postgres://devos:devos@localhost:5432/devos
# REDIS_URL=redis://localhost:6379
# SECRETS_PROVIDER=env
